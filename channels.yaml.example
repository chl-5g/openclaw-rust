# Channel Configuration Example
# Copy this file to your config directory as channels.yaml and customize the values

# Enable/disable all channels
enabled: true

# Channel to agent mapping
# Format: "channel_name": "agent_name"
channel_to_agent_map:
  telegram: "default"
  discord: "default"
  slack: "default"

# Channel-specific configuration (JSON format)
config:
  telegram:
    enabled: true
    bot_token: "YOUR_TELEGRAM_BOT_TOKEN"
    # Optional: webhook_url for receiving updates
    # webhook_url: "https://your-server.com/webhook/telegram"
  
  discord:
    enabled: true
    bot_token: "YOUR_DISCORD_BOT_TOKEN"
    # Optional: webhook URL for messages
    # webhook_url: "https://discord.com/api/webhooks/..."
    # Enable Discord gateway for real-time events
    use_gateway: true
  
  slack:
    enabled: true
    bot_token: "xoxb-YOUR-SLACK-BOT-TOKEN"
    # App-level token for workspace features
    # app_token: "xapp-YOUR-APP-TOKEN"
    # Incoming webhook for sending messages
    # webhook_url: "https://hooks.slack.com/services/..."
  
  teams:
    enabled: true
    # Microsoft Teams bot configuration
    app_id: "YOUR_APP_ID"
    app_password: "YOUR_APP_PASSWORD"
    tenant_id: "YOUR_TENANT_ID"
  
  feishu:
    enabled: true
    # Feishu (飞书) configuration
    app_id: "YOUR_FEISHU_APP_ID"
    app_secret: "YOUR_FEISHU_APP_SECRET"
  
  wecom:
    enabled: true
    # WeCom (企业微信) configuration
    corp_id: "YOUR_CORP_ID"
    agent_id: "YOUR_AGENT_ID"
    secret: "YOUR_SECRET"
  
  dingtalk:
    enabled: true
    # DingTalk (钉钉) configuration
    app_key: "YOUR_DINGTALK_APP_KEY"
    app_secret: "YOUR_DINGTALK_APP_SECRET"
  
  whatsapp:
    enabled: true
    # WhatsApp configuration (via WhatsApp Business API)
    phone_number_id: "YOUR_PHONE_NUMBER_ID"
    access_token: "YOUR_ACCESS_TOKEN"
    # Verify webhook
    # verify_token: "YOUR_VERIFY_TOKEN"
